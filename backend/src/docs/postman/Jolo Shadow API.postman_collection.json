        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "if (response.data?.accessToken) {\r",
                  "    pm.environment.set(\r",
                  "        \"accessToken\",\r",
                  "        response.data.accessToken\r",
                  "    );\r",
                  "}\r",
                  "\r",
                  "if (response.data?.refreshToken) {\r",
                  "    pm.environment.set(\r",
                  "        \"refreshToken\",\r",
                  "        response.data.refreshToken\r",
                  "    );\r",
                  "}\r",
                  "\r",
                  "if (response.data?.verificationToken) {\r",
                  "    pm.environment.set(\r",
                  "        \"verificationToken\",\r",
                  "        response.data.verificationToken\r",
                  "    );\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"firstName\": \"Lovesh\",\r\n  \"lastName\": \"Bodhani\",\r\n  \"email\": \"lovesh@test.com\",\r\n  \"password\": \"Password@123\",\r\n  \"companyName\": \"Jolo Technologies\",\r\n  \"industry\": \"Software\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
